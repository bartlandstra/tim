---
import shows from '../data/tourdates.json';

function formatDate(dateStr: string): string {
  const d = new Date(dateStr + 'T12:00:00');
  const months = ['jan', 'feb', 'mrt', 'apr', 'mei', 'jun', 'jul', 'aug', 'sep', 'okt', 'nov', 'dec'];
  const days = ['zo', 'ma', 'di', 'wo', 'do', 'vr', 'za'];
  return `${days[d.getDay()]} ${d.getDate()} ${months[d.getMonth()]}`;
}
---

<section id="tourdates" class="py-24 md:py-32 px-6 md:px-12">
  <div class="max-w-6xl mx-auto">
    <div class="section-line mb-6"></div>
    <h2 class="text-3xl md:text-4xl font-bold tracking-tight mb-4">
      Tour <span style="color: var(--color-accent);">Dates</span>
    </h2>
    <p class="text-lg mb-12 max-w-xl" style="color: var(--color-text-muted);">
      Aankomende optredens en concerten.
    </p>

    <!-- No shows message (hidden by default, shown by JS if all dates passed) -->
    <div id="no-shows" class="hidden text-center py-16">
      <p class="text-lg" style="color: var(--color-text-muted);">
        Er zijn momenteel geen geplande optredens.<br />
        <a href="#contact" class="underline transition-colors duration-300 hover:text-[var(--color-accent)]" style="color: var(--color-accent);">Neem contact op</a> voor boekingen.
      </p>
    </div>

    <div id="shows-list" class="space-y-1">
      {shows.map(show => (
        <div
          class="show-row group flex flex-col sm:flex-row sm:items-center gap-2 sm:gap-0 p-5 border-b transition-colors duration-300 hover:bg-[var(--color-surface)]"
          style="border-color: var(--color-surface);"
          data-date={show.date}
        >
          <!-- Date -->
          <div class="sm:w-32 shrink-0">
            <span class="text-sm font-bold uppercase tracking-wide" style="color: var(--color-accent);">
              {formatDate(show.date)}
            </span>
          </div>

          <!-- Venue & City -->
          <div class="flex-1 min-w-0">
            <div class="font-semibold text-white">{show.venue}</div>
            <div class="text-sm" style="color: var(--color-text-muted);">{show.city}</div>
          </div>

          <!-- Act -->
          <div class="flex-1 min-w-0 hidden md:block">
            <div class="text-sm" style="color: var(--color-text-muted);">{show.act}</div>
          </div>

          <!-- Tickets -->
          <div class="sm:w-32 shrink-0 sm:text-right">
            {show.url ? (
              <a href={show.url} target="_blank" rel="noopener" class="inline-block text-xs font-medium uppercase tracking-wide px-4 py-2 transition-all duration-300 hover:scale-105" style="background: var(--color-accent); color: var(--color-bg);">
                Tickets
              </a>
            ) : (
              <span class="text-xs font-medium uppercase tracking-wide px-4 py-2 border" style="border-color: var(--color-accent-dim); color: var(--color-accent);">
                Binnenkort
              </span>
            )}
          </div>
        </div>
      ))}
    </div>

    <div class="mt-12 text-center">
      <p class="text-sm" style="color: var(--color-text-muted);">
        Wil je Tim boeken voor jouw evenement?
        <a href="#contact" class="underline transition-colors duration-300 hover:text-[var(--color-accent)]" style="color: var(--color-accent);">Neem contact op</a>
      </p>
    </div>
  </div>
</section>

<script>
  // Hide past tour dates (runs client-side so it works between builds)
  function hidePastShows() {
    const today = new Date();
    today.setHours(0, 0, 0, 0);
    const rows = document.querySelectorAll('.show-row');
    let visibleCount = 0;

    rows.forEach(row => {
      const dateStr = (row as HTMLElement).dataset.date;
      if (dateStr) {
        const showDate = new Date(dateStr + 'T23:59:59');
        if (showDate < today) {
          (row as HTMLElement).style.display = 'none';
        } else {
          visibleCount++;
        }
      }
    });

    // Show "no shows" message if all dates have passed
    if (visibleCount === 0) {
      document.getElementById('no-shows')?.classList.remove('hidden');
      document.getElementById('shows-list')?.classList.add('hidden');
    }
  }

  hidePastShows();
</script>
